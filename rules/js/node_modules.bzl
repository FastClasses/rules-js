load(":providers.bzl", "JsLibraryInfo")

def create_node_modules_tree(ctx, deps, out_dir_name="node_modules"):
    symlinks = {}
    
    all_deps_map = {}
    for dep in deps:
        info = dep[JsLibraryInfo]
        all_deps_map[info.package_name] = info
        if hasattr(info, "deps"):
            for td in info.deps:
                all_deps_map[td.package_name] = td
                
    for info in all_deps_map.values():
        pkg_path = info.package_name
        if hasattr(info, "out_dir"):
            symlinks[pkg_path] = info.out_dir

    return ctx.actions.copied_dir(out_dir_name, symlinks)
